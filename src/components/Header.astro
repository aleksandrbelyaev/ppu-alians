<script>
    (function () {
      const navItem = document.querySelector('.nav-item--services');
      const root = document.querySelector('.mega-tabs');
      if (!navItem || !root) return;

      const tabs = Array.from(root.querySelectorAll('.mega-tab[data-mega-target]'));
      const panels = Array.from(root.querySelectorAll('.mega-panel[data-panel]'));
      let closeTimer = null;

      function activate(target) {
        tabs.forEach((tab) => {
          tab.classList.toggle('is-active', tab.dataset.megaTarget === target);
        });

        panels.forEach((panel) => {
          panel.classList.toggle('is-active', panel.dataset.panel === target);
        });
      }

      function openMenu() {
        window.clearTimeout(closeTimer);
        navItem.classList.add('is-open');
      }

      function closeMenu() {
        window.clearTimeout(closeTimer);
        closeTimer = window.setTimeout(() => {
          navItem.classList.remove('is-open');
          activate('ppu');
        }, 320);
      }

      tabs.forEach((tab) => {
        const target = tab.dataset.megaTarget;
        tab.addEventListener('mouseenter', () => {
          openMenu();
          activate(target);
        });
        tab.addEventListener('focus', () => {
          openMenu();
          activate(target);
        });
        tab.addEventListener('click', (event) => {
          event.preventDefault();
          openMenu();
          activate(target);
        });
      });

      navItem.addEventListener('mouseenter', openMenu);
      navItem.addEventListener('mouseleave', closeMenu);
      root.addEventListener('mouseenter', openMenu);
      root.addEventListener('mouseleave', closeMenu);

      const servicesLink = navItem.querySelector('.nav-link--services');
      if (servicesLink) {
        servicesLink.addEventListener('focus', openMenu);
      }

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          navItem.classList.remove('is-open');
          activate('ppu');
        }
      });

      activate('ppu');
    })();
</script>
