<script>
    (function () {
      const tabs = Array.from(document.querySelectorAll('.price-tab[data-price-tab]'));
      const panels = Array.from(document.querySelectorAll('.price-panel[data-price-panel]'));

      tabs.forEach(function (tab) {
        tab.addEventListener('click', function () {
          const target = tab.dataset.priceTab;

          tabs.forEach(function (item) {
            item.classList.toggle('is-active', item === tab);
          });

          panels.forEach(function (panel) {
            panel.classList.toggle('is-active', panel.dataset.pricePanel === target);
          });
        });
      });
    })();

    (function () {
      const type = document.getElementById('calc-type');
      const area = document.getElementById('calc-area');
      const complexity = document.getElementById('calc-complexity');
      const distance = document.getElementById('calc-distance');
      const total = document.getElementById('calc-total');

      if (!type || !area || !complexity || !distance || !total) return;

      function formatPrice(value) {
        return Math.round(value).toLocaleString('ru-RU') + ' ₽';
      }

      function updateTotal() {
        const rate = Number(type.value || 0);
        const meters = Math.max(Number(area.value || 0), 0);
        const multiplier = Number(complexity.value || 1);
        const distancePrice = Number(distance.value || 0);
        const result = (rate * meters * multiplier) + distancePrice;

        total.textContent = formatPrice(result);
      }

      [type, area, complexity, distance].forEach(function (field) {
        field.addEventListener('input', updateTotal);
        field.addEventListener('change', updateTotal);
      });

      updateTotal();
    })();
</script>
