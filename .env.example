# Keystatic в режиме GitHub (онлайн-редактирование на Vercel).
# Нужны только если в keystatic.config.ts storage.kind = 'github'.
# Создаются автоматически при подключении Keystatic GitHub App: https://keystatic.com/docs/github-mode
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=
# Публичный (доступен на клиенте) — имя установленного GitHub App
PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=
